FIRECRAWL_KEY="YOUR_KEY"
# If you want to use your self-hosted Firecrawl, add the following below:
# FIRECRAWL_BASE_URL="http://localhost:3002"
# FIRECRAWL_CONCURRENCY="2"

# Search provider settings:
# SEARCH_PROVIDER="tavily+exa-mcp" # default, or "tavily" / "exa-mcp" / "firecrawl"
# SEARCH_CONCURRENCY="2"
# SEARCH_RESULTS_LIMIT="5"
# SEARCH_TIMEOUT_MS="15000"
# SEARCH_SAME_URL_SIMILARITY_THRESHOLD="0.9"
# SEARCH_CROSS_URL_SIMILARITY_THRESHOLD="0.95"

# Tavily settings (required if SEARCH_PROVIDER="tavily"):
# TAVILY_KEY="tvly-YOUR_KEY"
# TAVILY_BASE_URL="https://api.tavily.com/search"
# TAVILY_SEARCH_DEPTH="advanced" # advanced | basic

# Exa MCP settings (for SEARCH_PROVIDER including "exa-mcp"):
# EXA_MCP_COMMAND="npx"
# EXA_MCP_ARGS="-y mcp-remote https://mcp.exa.ai/mcp"
# EXA_MCP_TIMEOUT_MS="25000"
# EXA_CONTEXT_MAX_CHARACTERS="12000"

OPENAI_KEY="YOUR_KEY"
CONTEXT_SIZE="128000"

# If you want to use other OpenAI compatible API, add the following below:
# OPENAI_ENDPOINT="http://localhost:11434/v1"
# CUSTOM_MODEL="llama3.1"

# If you want to use fireworks.ai's DeepSeek R1 model:
# FIREWORKS_KEY="YOUR_KEY"
